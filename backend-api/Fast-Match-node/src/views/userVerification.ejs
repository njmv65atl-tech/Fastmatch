<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Verification Code</title>
</head>

<body style="margin: 0; padding: 0; background-color: #f9f9f9; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;">

  <div style="max-width: 480px; margin: 0 auto; padding: 40px 20px;">
    <div style="background-color: #ffffff; border-radius: 12px; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05); padding: 40px 30px; text-align: left;">

      <!-- Header -->
      <h2 style="font-size: 20px; margin: 0 0 16px; color: #222;">Verification Code for Fast-Match</h2>

      <!-- Body -->
      <p style="font-size: 15px; color: #333; line-height: 1.6; margin: 0 0 16px;">
        Hello <strong><%= email %></strong>,
      </p>

      <p style="font-size: 15px; color: #333; line-height: 1.6; margin: 0 0 16px;">
        Please enter the verification code on Fast-Match to continue. This code will expire in 15 minutes.
      </p>

      <!-- OTP Box -->
      <div style="font-size: 28px; font-weight: bold; letter-spacing: 6px; color: #fc9e00; margin: 16px 0 24px;">
        <%= otp %>
      </div>

      <!-- Footer Note -->
      <p style="font-size: 14px; color: #666; margin-top: 24px;">
        If you didn't request this, you can safely ignore this email.
      </p>

      <!-- Signature -->
      <p style="font-size: 14px; color: #333; margin-top: 32px;">
        – Team Fast-Match
      </p>

      <!-- Copyright -->
      <div style="margin-top: 40px; font-size: 12px; color: #aaa; text-align: center;">
        © <%= year %> Fast-Match. All rights reserved.
      </div>

    </div>
  </div>

</body>

</html>
