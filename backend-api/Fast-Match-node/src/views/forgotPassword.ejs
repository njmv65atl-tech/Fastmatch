<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>OTP Verification</title>
</head>

<body
    style="margin: 0; padding: 0; background-color: #000000; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;">

    <div style="max-width: 440px; margin: 0 auto; padding: 40px 20px;">
        <div
            style="background-color: #FBF3E5; border-radius: 12px; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.05); padding: 40px 30px; text-align: center;">

            <!-- Logo -->
            <div style="margin-bottom: 24px;">
                <img src="https://i.ibb.co/xqRBW0sG/Image-34.png" alt="Logo"
                    style="display: block; margin: 0 auto; max-width: 100%; width: 120px; height: auto;" />
            </div>

            <!-- Title -->
            <h2 style="font-size: 20px; margin: 0 0 16px; color: #000;">OTP Verification</h2>

            <!-- Message -->
            <p style="font-size: 15px; color: #000; margin: 0 0 24px; line-height: 1.5;">
                Hello <strong>
                    <%= email %>
                </strong>,<br />
                Use the OTP below to complete your request.
            </p>

            <!-- OTP Box -->
            <div
                style="font-size: 24px;letter-spacing: 5px; background-color: #000000; display: inline-block; padding: 12px 20px; border-radius: 8px; font-weight: bold; color: #ffffff; margin-bottom: 24px; text-align: center;">
                <%= otp%>
            </div>

            <!-- Expiry Note -->
            <p style="font-size: 14px; color: #000; margin: 24px 0 0;">
                If you didn't request this, you can safely ignore this email.
            </p>

            <!-- Footer -->
            <div style="margin-top: 40px; font-size: 12px; color: #000;">
                © <%= year %> Fast-Match. All rights reserved.
            </div>

        </div>
    </div>

</body>

</html>