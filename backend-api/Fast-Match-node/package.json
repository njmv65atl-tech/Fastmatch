{
  "name": "fast-match",
  "version": "1.0.0",
  "description": "Fast-Match - Backend API",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "ts-node -r tsconfig-paths/register src/app.ts",
    "lint": "eslint src",
    "dev": "nodemon -r tsconfig-paths/register --exec \"npm run lint && ts-node -r tsconfig-paths/register src/app.ts\"",
    "build": "tsc && shx cp -r src/public dist/public && shx cp src/config/firebase/serviceAccountKey.json dist/config/firebase/serviceAccountKey.json && tsc-alias",
    "buildRun": "shx rm -rf dist/* && npm run build && node dist/app.js"
  },
