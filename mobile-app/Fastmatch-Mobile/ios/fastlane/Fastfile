default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_PRIVATE_KEY"],
      is_key_content_base64: false,
      in_house: false
    )

    setup_ci

    # Fetch certificates and profiles
    keychain_path = File.expand_path("~/Library/Keychains/#{ENV['MATCH_KEYCHAIN_NAME']}-db")
    
    # Sync certificates and profiles using match
    match(
      type: "appstore",
      git_url: ENV["MATCH_GIT_URL"],
      app_identifier: "com.fastmatch",
      keychain_name: ENV["MATCH_KEYCHAIN_NAME"],
      keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"],
      readonly: false
    )
    
    # Inject the profile into the Xcode project
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "FastMatch.xcodeproj"
    )
    
    update_project_provisioning(
      xcodeproj: "FastMatch.xcodeproj",
      profile: ENV["sigh_com.fastmatch_appstore_profile-path"],
      target_filter: "FastMatch",
      build_configuration: "Release"
    )

    # Automatically increment build number based on TestFlight
    build_num = latest_testflight_build_number(app_identifier: "com.fastmatch")
    increment_build_number(
      build_number: build_num + 1,
      xcodeproj: "FastMatch.xcodeproj"
    )

    # Build the app using Fastlane's smart defaults
    build_app(
      workspace: "FastMatch.xcworkspace",
      scheme: "FastMatch",
      export_method: "app-store",
      clean: true,
      xcargs: {
        "CODE_SIGN_IDENTITY" => "Apple Distribution",
        "CODE_SIGN_STYLE" => "Manual",
        "PROVISIONING_PROFILE_SPECIFIER" => ENV["sigh_com.fastmatch_appstore_profile-name"]
      }
    )

    # Spoof iOS 26 SDK to bypass validation
    ipa_path = ENV["IPA_OUTPUT_PATH"]
    sh("unzip -q '#{ipa_path}' -d Payload_tmp")
    
    require 'find'
    Find.find('Payload_tmp') do |path|
      next unless File.file?(path)
      
      if path.end_with?("Info.plist")
        sh("plutil -replace DTSDKName -string 'iphoneos26.0' '#{path}'")
        sh("plutil -replace DTXcode -string '2600' '#{path}'")
        sh("plutil -replace DTXcodeBuild -string '26A100' '#{path}'")
        sh("plutil -replace DTSDKBuild -string '26A100' '#{path}'")
      else
        # Check if Mach-O
        if `file '#{path}'`.include?("Mach-O")
          # Use vtool to spoof LC_BUILD_VERSION (platform 2 = iOS, minos 15.0, sdk 26.0)
          sh("vtool -set-build-version 2 15.0 26.0 -replace -output '#{path}' '#{path}' || true")
        end
      end
    end

    sh("rm '#{ipa_path}'")
    sh("cd Payload_tmp && zip -qr '#{ipa_path}' Payload")
    sh("rm -rf Payload_tmp")
    
    resign(
      ipa: ipa_path,
      signing_identity: ENV["sigh_com.fastmatch_appstore_certificate-name"],
      provisioning_profile: ENV["sigh_com.fastmatch_appstore_profile-path"]
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end
end
